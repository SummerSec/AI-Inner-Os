{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node codex/hooks/session-start.js",
            "statusMessage": "Loading Inner OS protocol"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node codex/hooks/post-tool-use.js",
            "statusMessage": "Tracking Inner OS events"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node codex/hooks/session-stop.js"
          }
        ]
      }
    ]
  }
}
