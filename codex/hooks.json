{
  "hooks": [
    {
      "name": "SessionStart",
      "type": "command",
      "command": "node codex/hooks/session-start.js"
    },
    {
      "name": "PreToolUse",
      "type": "command",
      "matcher": ".*",
      "command": "node codex/hooks/pre-tool-use.js"
    },
    {
      "name": "PostToolUse",
      "type": "command",
      "matcher": ".*",
      "command": "node codex/hooks/post-tool-use.js"
    },
    {
      "name": "SessionStop",
      "type": "command",
      "command": "node codex/hooks/session-stop.js"
    }
  ]
}
