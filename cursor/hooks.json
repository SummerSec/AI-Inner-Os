{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node cursor/hooks/session-start.js",
        "type": "command",
        "timeout": 5
      }
    ],
    "postToolUse": [
      {
        "command": "node cursor/hooks/post-tool-use.js",
        "type": "command",
        "timeout": 5
      }
    ],
    "stop": [
      {
        "command": "node cursor/hooks/stop.js",
        "type": "command",
        "timeout": 5
      }
    ]
  }
}
